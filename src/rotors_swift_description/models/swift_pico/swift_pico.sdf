    </link>
    <joint name='swift_pico/m3_joint' type='revolute'>
      <child>swift_pico/m3</child>
      <parent>swift_pico/base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
